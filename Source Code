# ═══════════════════════════════════════════════════════════════════════════
#  PURE LOGIC
# ═══════════════════════════════════════════════════════════════════════════
def lerp(a, b, t): return a + (b - a) * t

def offset_at(obj, frame):
    kfs = obj["keyframes"]
    if not kfs: return (0.0, 0.0)
    frames = sorted(kfs)
    if frame <= frames[0]:  return tuple(kfs[frames[0]])
    if frame >= frames[-1]: return tuple(kfs[frames[-1]])
    for i in range(len(frames) - 1):
        a, b = frames[i], frames[i + 1]
        if a <= frame <= b:
            t = (frame - a) / (b - a) if b != a else 0.0
            return (lerp(kfs[a][0], kfs[b][0], t), lerp(kfs[a][1], kfs[b][1], t))
    return (0.0, 0.0)

def opacity_at(obj, frame):
    okf = obj.get("opacity_kf", {})
    if not okf: return 1.0
    frames = sorted(okf)
    if frame <= frames[0]:  return okf[frames[0]]
    if frame >= frames[-1]: return okf[frames[-1]]
    for i in range(len(frames) - 1):
        a, b = frames[i], frames[i + 1]
        if a <= frame <= b:
            t = (frame - a) / (b - a) if b != a else 0.0
            return lerp(okf[a], okf[b], t)
    return 1.0

def shifted_points(obj, frame):
    dx, dy = offset_at(obj, frame)
    return [(x + dx, y + dy) for (x, y) in obj["points"]]

def blend_color(hex_color, opacity, bg_hex="#ffffff"):
    if opacity >= 1.0: return hex_color
    r, g, b = int(hex_color[1:3],16), int(hex_color[3:5],16), int(hex_color[5:7],16)
    br, bg_, bb = int(bg_hex[1:3],16), int(bg_hex[3:5],16), int(bg_hex[5:7],16)
    return "#%02x%02x%02x" % (
        int(r*opacity+br*(1-opacity)),
        int(g*opacity+bg_*(1-opacity)),
        int(b*opacity+bb*(1-opacity)))

def make_obj(type_, points, color="#4dabf7", width=4, text=""):
    return {"type": type_, "points": [list(p) for p in points],
            "color": color, "width": width, "text": text,
            "keyframes": {0: [0.0, 0.0]}, "opacity_kf": {0: 1.0}}

def _offset_line(p1, p2, dist):
    dx, dy = p2[0]-p1[0], p2[1]-p1[1]
    L = max(1, math.hypot(dx, dy))
    return ((p1[0]-dy/L*dist, p1[1]+dx/L*dist),
            (p2[0]-dy/L*dist, p2[1]+dx/L*dist))

def add_orbit_keyframes(obj, cx, cy, radius, total_frames, revolutions=1):
    base = obj["points"][0] if obj["points"] else [cx, cy]
    bx, by = base[0], base[1]
    for f in range(total_frames):
        angle = 2 * math.pi * revolutions * f / total_frames
        obj["keyframes"][f] = [(cx + radius * math.cos(angle)) - bx,
                               (cy + radius * math.sin(angle)) - by]


# ── Pillow rendering ──────────────────────────────────────────────────────
def render_to_pil(objects, frame, size=(CANVAS_W, CANVAS_H), bg="white"):
    img = Image.new("RGB", size, bg)
    draw = ImageDraw.Draw(img)
    for obj in objects:
        opa = opacity_at(obj, frame)
        if opa < 0.02: continue
        pts = shifted_points(obj, frame)
        col = blend_color(obj["color"], opa)
        w = max(1, int(obj["width"]))
        t = obj["type"]
        if t == "pen" and len(pts) >= 2:
            draw.line(pts, fill=col, width=w, joint="curve")
        elif t == "line" and len(pts) == 2:
            draw.line(pts, fill=col, width=w)
        elif t == "double_line" and len(pts) == 2:
            for d in (w+1, -(w+1)):
                a, b = _offset_line(pts[0], pts[1], d/2)
                draw.line([a, b], fill=col, width=w)
        elif t == "triple_line" and len(pts) == 2:
            draw.line(pts, fill=col, width=w)
            for d in (w+2, -(w+2)):
                a, b = _offset_line(pts[0], pts[1], d)
                draw.line([a, b], fill=col, width=w)
        elif t == "rect" and len(pts) == 2:
            draw.rectangle([min(pts[0][0],pts[1][0]),min(pts[0][1],pts[1][1]),
                           max(pts[0][0],pts[1][0]),max(pts[0][1],pts[1][1])],
                           outline=col, width=w)
        elif t == "circle" and len(pts) == 2:
            draw.ellipse([min(pts[0][0],pts[1][0]),min(pts[0][1],pts[1][1]),
                         max(pts[0][0],pts[1][0]),max(pts[0][1],pts[1][1])],
                         outline=col, width=w)
        elif t == "dot" and len(pts) == 2:
            draw.ellipse([min(pts[0][0],pts[1][0]),min(pts[0][1],pts[1][1]),
                         max(pts[0][0],pts[1][0]),max(pts[0][1],pts[1][1])], fill=col)
        elif t == "arrow" and len(pts) == 2:
            draw.line(pts, fill=col, width=w)
            ang = math.atan2(pts[1][1]-pts[0][1], pts[1][0]-pts[0][0])
            sz = 10 + w*2
            w1 = [pts[1][0]+sz*math.cos(ang+2.6), pts[1][1]+sz*math.sin(ang+2.6)]
            w2 = [pts[1][0]+sz*math.cos(ang-2.6), pts[1][1]+sz*math.sin(ang-2.6)]
            draw.polygon([pts[1], w1, w2], fill=col)
        elif t == "curved_arrow" and len(pts) >= 3:
            draw.line(pts, fill=col, width=w, joint="curve")
            ang = math.atan2(pts[-1][1]-pts[-2][1], pts[-1][0]-pts[-2][0])
            sz = 10 + w*2
            w1 = [pts[-1][0]+sz*math.cos(ang+2.6), pts[-1][1]+sz*math.sin(ang+2.6)]
            w2 = [pts[-1][0]+sz*math.cos(ang-2.6), pts[-1][1]+sz*math.sin(ang-2.6)]
            draw.polygon([pts[-1], w1, w2], fill=col)
        elif t == "text" and pts:
            try: font = ImageFont.truetype("arial.ttf", w)
            except:
                try: font = ImageFont.truetype("DejaVuSans.ttf", w)
                except: font = ImageFont.load_default()
            draw.text(pts[0], obj.get("text",""), fill=col, font=font)
    return img

def export_gif(objects, total_frames, fps, path):
    frames = [render_to_pil(objects, f) for f in range(total_frames)]
    dur = max(20, int(1000 / max(1, fps)))
    frames[0].save(path, save_all=True, append_images=frames[1:],
                   duration=dur, loop=0, disposal=2)
    return path


