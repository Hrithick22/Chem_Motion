def _text_color(hex_bg):
    r, g, b = int(hex_bg[1:3],16), int(hex_bg[3:5],16), int(hex_bg[5:7],16)
    return "#ffffff" if (r*0.299 + g*0.587 + b*0.114) < 150 else "#111111"

def _atom_objects(sym, cx, cy, radius=30):
    """Create a filled-circle atom with symbol and atomic number."""
    info = ELEM_BY_SYM.get(sym)
    if not info: return []
    z, sym, name, cat = info
    color = ATOM_COLORS[sym]
    tc = _text_color(color)
    circle = make_obj("dot", [[cx-radius, cy-radius],[cx+radius, cy+radius]],
                      color=color, width=2)
    # Symbol label (centered)
    lbl = make_obj("text", [[cx - len(sym)*7, cy - 12]],
                   color=tc, width=20, text=sym)
    # Atomic number (small, below symbol)
    num = make_obj("text", [[cx - len(str(z))*4, cy + 10]],
                   color=tc, width=11, text=str(z))
    return [circle, lbl, num]

def create_template(name, cx, cy):
    objs = []
    if name in ELEM_BY_SYM:
        objs = _atom_objects(name, cx, cy)
    elif name == "e-":
        objs = [make_obj("dot", [[cx-6,cy-6],[cx+6,cy+6]], "#ffd43b", 2)]
    elif name == "p+":
        objs = [make_obj("dot", [[cx-8,cy-8],[cx+8,cy+8]], "#ff6b6b", 2),
                make_obj("text", [[cx-5,cy-8]], "#fff", 13, "p\u207A")]
    elif name == "n0":
        objs = [make_obj("dot", [[cx-8,cy-8],[cx+8,cy+8]], "#868e96", 2),
                make_obj("text", [[cx-5,cy-8]], "#fff", 13, "n\u2070")]
    elif name == "single":
        objs = [make_obj("line", [[cx-40,cy],[cx+40,cy]], "#555", 3)]
    elif name == "double":
        objs = [make_obj("double_line", [[cx-40,cy],[cx+40,cy]], "#555", 3)]
    elif name == "triple":
        objs = [make_obj("triple_line", [[cx-40,cy],[cx+40,cy]], "#555", 3)]
    elif name == "rxn_arrow":
        objs = [make_obj("arrow", [[cx-60,cy],[cx+60,cy]], "#333", 3)]
    elif name == "eq_arrow":
        objs = [make_obj("arrow", [[cx-50,cy-4],[cx+50,cy-4]], "#333", 2),
                make_obj("arrow", [[cx+50,cy+4],[cx-50,cy+4]], "#333", 2)]
    elif name == "mech_arrow":
        pts = [[cx-40+80*i/19, cy-30*math.sin(math.pi*i/19)] for i in range(20)]
        objs = [make_obj("curved_arrow", pts, "#e64980", 3)]
    elif name == "orbital":
        objs = [make_obj("circle", [[cx-35,cy-20],[cx+35,cy+20]], "#4dabf7", 2)]
    elif name == "nucleus":
        objs = [make_obj("dot", [[cx-18,cy-18],[cx+18,cy+18]], "#e64980", 2)]
    elif name == "plus":
        objs = [make_obj("text", [[cx-8,cy-14]], "#333", 22, "+")]
    elif name == "yields":
        objs = [make_obj("text", [[cx-8,cy-14]], "#333", 22, "\u2192")]
    return objs

