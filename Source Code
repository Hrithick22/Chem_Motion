#  THE APPLICATION
# ═══════════════════════════════════════════════════════════════════════════
class ChemMotionApp:
    def __init__(self, root):
        self.root = root
        root.title("ChemMotion v3  \u2014  Full Periodic Table Edition")
        root.configure(bg=BG)
        self.objects, self.tool, self.color, self.width = [], "select", "#4dabf7", 4
        self.total_frames, self.fps, self.current_frame = 60, 12, 0
        self.onion = tk.BooleanVar(value=False)
        self.selected, self.playing, self.canvas, self._drag = None, False, None, None

        self._build_toolbar()
        self._build_main_area()
        self._build_timeline()
        self._bind_canvas()
        self.render()

    def _build_toolbar(self):
        bar = tk.Frame(self.root, bg=PANEL); bar.pack(side="top", fill="x")
        tools = [("Select","select"),("Pen","pen"),("Line","line"),("Arrow","arrow"),
                 ("Circle","circle"),("Dot","dot"),("Rect","rect"),("Text","text")]
        self.tool_btns = {}
        for label, name in tools:
            b = tk.Button(bar, text=label, width=7, relief="flat", bg=PANEL, fg=TEXT,
                          activebackground=ACCENT, command=lambda n=name: self.set_tool(n))
            b.pack(side="left", padx=1, pady=5); self.tool_btns[name] = b

        tk.Frame(bar, bg="#444", width=2, height=22).pack(side="left", padx=6)
        self.color_btn = tk.Button(bar, text="Colour", width=7, relief="flat",
                                   bg=self.color, fg="#111", command=self.pick_color)
        self.color_btn.pack(side="left", padx=2)
        tk.Label(bar, text="Size", bg=PANEL, fg=TEXT).pack(side="left", padx=(8,2))
        self.width_spin = tk.Spinbox(bar, from_=1, to=60, width=3, command=self._on_width)
        self.width_spin.delete(0,"end"); self.width_spin.insert(0, str(self.width))
        self.width_spin.pack(side="left")
        tk.Frame(bar, bg="#444", width=2, height=22).pack(side="left", padx=6)
        for txt, cmd in [("Dup", self.duplicate_selected), ("Del", self.delete_selected),
                         ("\u2191", self.layer_up), ("\u2193", self.layer_down)]:
            tk.Button(bar, text=txt, width=4, relief="flat", bg=PANEL, fg=TEXT,
                      command=cmd).pack(side="left", padx=1)
        tk.Button(bar, text="Clear", width=5, relief="flat", bg=PANEL, fg="#ff6b6b",
                  command=self.clear_all).pack(side="left", padx=1)
        self.set_tool("select")

    def _build_main_area(self):
        main = tk.Frame(self.root, bg=BG)
        main.pack(side="top", fill="both", expand=True)

        # ── Scrollable template sidebar ──
        side = tk.Frame(main, bg=SIDEBAR, width=160)
        side.pack(side="left", fill="y", padx=(6,0), pady=6)
        side.pack_propagate(False)

        tk.Label(side, text="\u2699 Templates", font=("Segoe UI", 11, "bold"),
                 bg=SIDEBAR, fg=ACCENT).pack(pady=(6,2))

        # Search box
        self.search_var = tk.StringVar()
        self.search_var.trace_add("write", self._on_search)
        se = tk.Entry(side, textvariable=self.search_var, width=18, font=("Segoe UI",9),
                      bg="#333", fg=TEXT, insertbackground=TEXT, relief="flat")
        se.pack(padx=6, pady=4, ipady=2)
        tk.Label(side, text="Type to search elements", font=("Segoe UI",7),
                 bg=SIDEBAR, fg=MUTED).pack()

        sf = tk.Frame(side, bg=SIDEBAR)
        sf.pack(fill="both", expand=True)
        self._scroll_canvas = tk.Canvas(sf, bg=SIDEBAR, highlightthickness=0, width=148)
        sb = tk.Scrollbar(sf, orient="vertical", command=self._scroll_canvas.yview)
        self._inner = tk.Frame(self._scroll_canvas, bg=SIDEBAR)
        self._inner.bind("<Configure>",
            lambda e: self._scroll_canvas.configure(scrollregion=self._scroll_canvas.bbox("all")))
        self._scroll_canvas.create_window((0,0), window=self._inner, anchor="nw")
        self._scroll_canvas.configure(yscrollcommand=sb.set)
        self._scroll_canvas.pack(side="left", fill="both", expand=True)
        sb.pack(side="right", fill="y")
        # Mouse wheel scrolling
        self._scroll_canvas.bind("<MouseWheel>",
            lambda e: self._scroll_canvas.yview_scroll(-1*(e.delta//120), "units"))

        self._all_buttons = []
        self._populate_sidebar()

        # ── Canvas ──
        wrap = tk.Frame(main, bg=BG)
        wrap.pack(side="left", padx=8, pady=6)
        self.canvas = tk.Canvas(wrap, width=CANVAS_W, height=CANVAS_H, bg="white",
                                highlightthickness=1, highlightbackground="#555")
        self.canvas.pack()

    def _populate_sidebar(self, filter_text=""):
        for w in self._inner.winfo_children():
            w.destroy()
        self._all_buttons = []
        ft = filter_text.lower()

        for section_name, section_color, items in TEMPLATE_SECTIONS:
            filtered = [(k, lbl) for k, lbl in items
                        if not ft or ft in lbl.lower() or ft in k.lower()]
            if not filtered:
                continue
            # Category header with colour chip
            hf = tk.Frame(self._inner, bg=SIDEBAR)
            hf.pack(anchor="w", padx=4, pady=(8,2), fill="x")
            tk.Frame(hf, bg=section_color, width=10, height=10).pack(side="left", padx=(0,4))
            tk.Label(hf, text=section_name, font=("Segoe UI",8,"bold"),
                     bg=SIDEBAR, fg=section_color).pack(side="left")

            for key, label in filtered:
                col = ATOM_COLORS.get(key, SIDEBAR)
                bf = tk.Frame(self._inner, bg=SIDEBAR)
                bf.pack(fill="x", padx=4, pady=0)
                # Small colour swatch
                tk.Frame(bf, bg=col, width=8, height=8).pack(side="left", padx=(2,4), pady=3)
                b = tk.Button(bf, text=label, anchor="w", relief="flat",
                              bg=SIDEBAR, fg=TEXT, activebackground="#3a3a4a",
                              font=("Segoe UI", 8),
                              command=lambda k=key: self.stamp_template(k))
                b.pack(side="left", fill="x", expand=True)
                self._all_buttons.append((key, label, b))

    def _on_search(self, *_):
        self._populate_sidebar(self.search_var.get().strip())

    def _build_timeline(self):
        tl = tk.Frame(self.root, bg=PANEL); tl.pack(side="top", fill="x", ipady=4)
        r1 = tk.Frame(tl, bg=PANEL); r1.pack(fill="x", padx=8)

        self.play_btn = tk.Button(r1, text="\u25B6 Play", width=7, relief="flat",
                                  bg=ACCENT, fg="#111", command=self.toggle_play)
        self.play_btn.pack(side="left", padx=(0,6))
        self.frame_var = tk.IntVar(value=0)
        self.slider = tk.Scale(r1, from_=0, to=self.total_frames-1, orient="horizontal",
                               length=380, variable=self.frame_var, showvalue=False,
                               bg=PANEL, fg=TEXT, troughcolor="#444",
                               highlightthickness=0, command=self._on_slider)
        self.slider.pack(side="left", padx=4)
        self.frame_lbl = tk.Label(r1, text="0/59", bg=PANEL, fg=TEXT, width=8)
        self.frame_lbl.pack(side="left")
        tk.Checkbutton(r1, text="Onion", variable=self.onion, bg=PANEL, fg=TEXT,
                       selectcolor=PANEL, activebackground=PANEL,
                       command=self.render).pack(side="left", padx=6)
        tk.Label(r1, text="Frames", bg=PANEL, fg=MUTED).pack(side="left", padx=(6,2))
        self.frames_spin = tk.Spinbox(r1, from_=2, to=600, width=4, command=self._on_total)
        self.frames_spin.delete(0,"end"); self.frames_spin.insert(0, str(self.total_frames))
        self.frames_spin.pack(side="left")
        tk.Label(r1, text="FPS", bg=PANEL, fg=MUTED).pack(side="left", padx=(6,2))
        self.fps_spin = tk.Spinbox(r1, from_=1, to=60, width=3, command=self._on_fps)
        self.fps_spin.delete(0,"end"); self.fps_spin.insert(0, str(self.fps))
        self.fps_spin.pack(side="left")

        r2 = tk.Frame(tl, bg=PANEL); r2.pack(fill="x", padx=8, pady=(3,0))
        for txt, cmd in [("Set Key",self.set_keyframe),("Del Key",self.del_keyframe),
                         ("Orbit",self.add_orbit),("Fade In",self.fade_in),
                         ("Fade Out",self.fade_out)]:
            tk.Button(r2, text=txt, width=7, relief="flat", bg=PANEL, fg=TEXT,
                      command=cmd).pack(side="left", padx=2)
        tk.Frame(r2, bg="#444", width=2, height=20).pack(side="left", padx=6)
        tk.Button(r2, text="Save", width=5, relief="flat", bg=PANEL, fg=TEXT,
                  command=self.save_project).pack(side="left", padx=2)
        tk.Button(r2, text="Open", width=5, relief="flat", bg=PANEL, fg=TEXT,
                  command=self.load_project).pack(side="left", padx=2)
        tk.Button(r2, text="\u2B07 Export GIF", relief="flat", bg="#69db7c", fg="#111",
                  width=11, command=self.export).pack(side="left", padx=8)

        self.status = tk.Label(self.root, text="Ready. Pick elements from Templates or draw.",
                               bg=BG, fg=MUTED, anchor="w")
        self.status.pack(side="top", fill="x", padx=10, pady=(2,5))

    # ── Tool handlers ──
    def set_tool(self, name):
        self.tool = name
        for n, b in self.tool_btns.items():
            b.config(bg=ACCENT if n==name else PANEL, fg="#111" if n==name else TEXT)
        if self.canvas:
            self.canvas.config(cursor="hand2" if name=="select" else "crosshair")

    def pick_color(self):
        c = colorchooser.askcolor(color=self.color)
        if c and c[1]: self.color = c[1]; self.color_btn.config(bg=self.color)

    def _on_width(self):
        try: self.width = int(self.width_spin.get())
        except: pass
    def _on_total(self):
        try:
            self.total_frames = max(2, int(self.frames_spin.get()))
            self.slider.config(to=self.total_frames-1)
            if self.current_frame >= self.total_frames:
                self.current_frame = self.total_frames-1; self.frame_var.set(self.current_frame)
            self._update_frame_label()
        except: pass
    def _on_fps(self):
        try: self.fps = max(1, int(self.fps_spin.get()))
        except: pass

    # ── Timeline ──
    def _on_slider(self, _=None):
        self.current_frame = self.frame_var.get(); self._update_frame_label(); self.render()
    def _update_frame_label(self):
        self.frame_lbl.config(text="%d/%d" % (self.current_frame, self.total_frames-1))
    def toggle_play(self):
        self.playing = not self.playing
        self.play_btn.config(text="\u23F8 Stop" if self.playing else "\u25B6 Play")
        if self.playing: self._play_step()
    def _play_step(self):
        if not self.playing: return
        self.current_frame = (self.current_frame+1) % self.total_frames
        self.frame_var.set(self.current_frame); self._update_frame_label(); self.render()
        self.root.after(int(1000/max(1,self.fps)), self._play_step)

    # ── Canvas ──
    def _bind_canvas(self):
        self.canvas.bind("<Button-1>", self.on_press)
        self.canvas.bind("<B1-Motion>", self.on_drag)
        self.canvas.bind("<ButtonRelease-1>", self.on_release)

    def on_press(self, e):
        x, y = e.x, e.y
        if self.tool == "select":
            self.selected = self._hit_test(x, y)
            if self.selected is not None:
                obj = self.objects[self.selected]
                ox, oy = offset_at(obj, self.current_frame)
                self._drag = {"start": (x,y), "obj_off": (ox, oy)}
            self.render()
        elif self.tool == "text":
            s = simpledialog.askstring("Text", "Enter text / label:")
            if s:
                self.objects.append(make_obj("text",[[x,y]], self.color, max(10,self.width*4), s))
                self.render()
        else:
            self._drag = {"start": (x,y), "pts": [[x,y]]}

    def on_drag(self, e):
        x, y = e.x, e.y
        if self._drag is None: return
        if self.tool == "select" and self.selected is not None:
            sx,sy = self._drag["start"]; ox,oy = self._drag["obj_off"]
            self.objects[self.selected]["keyframes"][self.current_frame] = [ox+(x-sx), oy+(y-sy)]
            self.render()
        elif self.tool == "pen":
            self._drag["pts"].append([x,y]); self._live_preview()
        elif self.tool in ("line","arrow","rect","circle","dot"):
            self._drag["pts"] = [list(self._drag["start"]), [x,y]]; self._live_preview()

    def on_release(self, e):
        if self._drag is None: return
        if self.tool == "select": self._drag = None; return
        pts = self._drag.get("pts", [])
        valid = (self.tool=="pen" and len(pts)>=2) or (self.tool!="pen" and len(pts)==2 and pts[0]!=pts[1])
        if valid: self.objects.append(make_obj(self.tool, pts, self.color, self.width))
        self._drag = None; self.render()

    def _hit_test(self, x, y, threshold=16):
        best, best_d = None, threshold
        for i, obj in enumerate(self.objects):
            for px, py in shifted_points(obj, self.current_frame):
                d = math.hypot(px-x, py-y)
                if d < best_d: best, best_d = i, d
        return best

    # ── Templates ──
    def stamp_template(self, name):
        cx, cy = CANVAS_W//2, CANVAS_H//2
        new = create_template(name, cx, cy)
        self.objects.extend(new)
        if new: self.selected = len(self.objects)-1
        self.set_tool("select"); self.render()
        lbl = ELEM_BY_SYM[name][2] if name in ELEM_BY_SYM else name
        self.status.config(text="Added: %s. Drag to position." % lbl)

    # ── Keyframes & Motion ──
    def set_keyframe(self):
        if self.selected is None: self.status.config(text="Select an object first."); return
        obj = self.objects[self.selected]
        obj["keyframes"][self.current_frame] = list(offset_at(obj, self.current_frame))
        self.status.config(text="Key set at frame %d." % self.current_frame); self.render()

    def del_keyframe(self):
        if self.selected is None: return
        obj = self.objects[self.selected]
        if self.current_frame in obj["keyframes"] and self.current_frame != 0:
            del obj["keyframes"][self.current_frame]; self.render()

    def add_orbit(self):
        if self.selected is None: self.status.config(text="Select an object first."); return
        r = simpledialog.askinteger("Orbit","Radius (pixels):", initialvalue=80, minvalue=10, maxvalue=400)
        if not r: return
        cx = simpledialog.askinteger("Orbit","Center X (0-%d):" % CANVAS_W, initialvalue=CANVAS_W//2)
        if cx is None: return
        cy = simpledialog.askinteger("Orbit","Center Y (0-%d):" % CANVAS_H, initialvalue=CANVAS_H//2)
        if cy is None: return
        add_orbit_keyframes(self.objects[self.selected], cx, cy, r, self.total_frames)
        self.status.config(text="Orbit added! Press Play."); self.render()

    def fade_in(self):
        if self.selected is None: self.status.config(text="Select an object first."); return
        dur = simpledialog.askinteger("Fade In","Duration (frames):", initialvalue=10, minvalue=1)
        if not dur: return
        okf = self.objects[self.selected].setdefault("opacity_kf", {})
        s, e = self.current_frame, min(self.total_frames-1, self.current_frame+dur)
        okf[s] = 0.0; okf[e] = 1.0
        self.status.config(text="Fade in: %d\u2192%d." % (s,e)); self.render()

    def fade_out(self):
        if self.selected is None: self.status.config(text="Select an object first."); return
        dur = simpledialog.askinteger("Fade Out","Duration (frames):", initialvalue=10, minvalue=1)
        if not dur: return
        okf = self.objects[self.selected].setdefault("opacity_kf", {})
        s, e = self.current_frame, min(self.total_frames-1, self.current_frame+dur)
        okf[s] = 1.0; okf[e] = 0.0
        self.status.config(text="Fade out: %d\u2192%d." % (s,e)); self.render()

    # ── Object management ──
    def duplicate_selected(self):
        if self.selected is None: return
        dup = copy.deepcopy(self.objects[self.selected])
        for p in dup["points"]: p[0]+=20; p[1]+=20
        self.objects.append(dup); self.selected = len(self.objects)-1; self.render()
    def delete_selected(self):
        if self.selected is not None:
            self.objects.pop(self.selected); self.selected = None; self.render()
    def layer_up(self):
        if self.selected is not None and self.selected < len(self.objects)-1:
            i = self.selected
            self.objects[i], self.objects[i+1] = self.objects[i+1], self.objects[i]
            self.selected = i+1; self.render()
    def layer_down(self):
        if self.selected is not None and self.selected > 0:
            i = self.selected
            self.objects[i], self.objects[i-1] = self.objects[i-1], self.objects[i]
            self.selected = i-1; self.render()
    def clear_all(self):
        if self.objects and messagebox.askyesno("Clear","Delete everything?"):
            self.objects.clear(); self.selected = None; self.render()

    # ── Rendering ──
    def _live_preview(self):
        self.render()
        self._draw_obj_on_canvas(make_obj(self.tool, self._drag["pts"], self.color, self.width),
                                 self.current_frame)
    def render(self):
        self.canvas.delete("all")
        if self.onion.get() and self.current_frame > 0:
            for obj in self.objects:
                self._draw_obj_on_canvas(obj, self.current_frame-1, ghost=True)
        for i, obj in enumerate(self.objects):
            self._draw_obj_on_canvas(obj, self.current_frame, selected=(i==self.selected))
        self._update_frame_label()

    def _draw_obj_on_canvas(self, obj, frame, selected=False, ghost=False):
        opa = 0.18 if ghost else opacity_at(obj, frame)
        if opa < 0.02: return
        pts = shifted_points(obj, frame)
        col = blend_color(obj["color"] if not ghost else "#c0c0c0", opa)
        w = max(1, int(obj["width"])); t = obj["type"]
        flat = [c for p in pts for c in p]

        if t=="pen" and len(pts)>=2:
            self.canvas.create_line(*flat, fill=col, width=w, smooth=True, capstyle="round")
        elif t=="line" and len(pts)==2:
            self.canvas.create_line(*flat, fill=col, width=w)
        elif t=="double_line" and len(pts)==2:
            g = max(3, w+2)
            for d in (g/2, -g/2):
                a,b = _offset_line(pts[0], pts[1], d)
                self.canvas.create_line(a[0],a[1],b[0],b[1], fill=col, width=w)
        elif t=="triple_line" and len(pts)==2:
            g = max(4, w+3)
            self.canvas.create_line(*flat, fill=col, width=w)
            for d in (g, -g):
                a,b = _offset_line(pts[0], pts[1], d)
                self.canvas.create_line(a[0],a[1],b[0],b[1], fill=col, width=w)
        elif t=="arrow" and len(pts)==2:
            self.canvas.create_line(*flat, fill=col, width=w, arrow="last", arrowshape=(14,16,6))
        elif t=="curved_arrow" and len(pts)>=3:
            self.canvas.create_line(*flat, fill=col, width=w, smooth=True, arrow="last", arrowshape=(14,16,6))
        elif t=="rect" and len(pts)==2:
            self.canvas.create_rectangle(*flat, outline=col, width=w)
        elif t=="circle" and len(pts)==2:
            self.canvas.create_oval(*flat, outline=col, width=w)
        elif t=="dot" and len(pts)==2:
            self.canvas.create_oval(*flat, fill=col, outline=col)
        elif t=="text" and pts:
            self.canvas.create_text(pts[0][0], pts[0][1], text=obj.get("text",""),
                                    fill=col, anchor="nw", font=("Segoe UI", max(8,w)))
        if selected and pts:
            xs=[p[0] for p in pts]; ys=[p[1] for p in pts]
            self.canvas.create_rectangle(min(xs)-6,min(ys)-6,max(xs)+6,max(ys)+6,
                                         outline=ACCENT, dash=(4,3))

    # ── File I/O ──
    def export(self):
        if not self.objects: messagebox.showinfo("Empty","Draw something first."); return
        path = filedialog.asksaveasfilename(defaultextension=".gif",
                                             filetypes=[("GIF","*.gif")])
        if not path: return
        was = self.playing; self.playing = False
        self.status.config(text="Exporting %d frames..." % self.total_frames); self.root.update()
        try:
            export_gif(self.objects, self.total_frames, self.fps, path)
            self.status.config(text="Exported: " + path)
            messagebox.showinfo("Done", "Saved:\n" + path)
        except Exception as ex: messagebox.showerror("Error", str(ex))
        self.playing = was

    def save_project(self):
        path = filedialog.asksaveasfilename(defaultextension=".json",
                                             filetypes=[("Project","*.json")])
        if not path: return
        with open(path,"w") as f:
            json.dump({"total_frames":self.total_frames,"fps":self.fps,"objects":self.objects}, f)
        self.status.config(text="Saved: " + path)

    def load_project(self):
        path = filedialog.askopenfilename(filetypes=[("Project","*.json")])
        if not path: return
        with open(path) as f: data = json.load(f)
        self.total_frames = data.get("total_frames", 60)
        self.fps = data.get("fps", 12)
        for obj in data.get("objects", []):
            obj["keyframes"] = {int(k):v for k,v in obj["keyframes"].items()}
            obj["opacity_kf"] = {int(k):v for k,v in obj.get("opacity_kf",{}).items()}
        self.objects = data.get("objects", [])
        self.selected = None; self.current_frame = 0; self.frame_var.set(0)
        self.slider.config(to=self.total_frames-1); self.render()
        self.status.config(text="Loaded: " + path)


